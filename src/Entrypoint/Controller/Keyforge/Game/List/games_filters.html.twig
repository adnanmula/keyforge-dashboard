<div class="row">
    <div>
        <a style="position: fixed; bottom: 20px; right: 20px; z-index: 99999" class="btn btn-dark" data-bs-toggle="offcanvas" href="#games-filters" role="button" aria-expanded="false"><i class="bi bi-filter"></i></a>
    </div>
</div>
<div class="offcanvas offcanvas-start filters-margin" tabindex="-1" id="games-filters" data-bs-scroll="true" data-bs-backdrop="false" style="z-index: 1000">
    <div class="offcanvas-header">
        <h5>{{ 'menu.filters'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
    </div>
    <div class="offcanvas-body" style="overflow-x: hidden">
        <div class="mb-3">
            <label for="winner-selector" class="form-label fw-bold">{{ 'game.winner'|trans }}</label>
            <select id="winner-selector" class="form-select">
                {% for id, name in friends %}
                    <option value="{{ id }}">{{ name }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="mb-3">
            <label for="loser-selector" class="form-label fw-bold">{{ 'game.loser'|trans }}</label>
            <select id="loser-selector" class="form-select">
                {% for id, name in friends %}
                    <option value="{{ id }}">{{ name }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="mb-3">
            <label for="score-selector" class="form-label fw-bold">{{ 'game.keys'|trans }}</label>
            <select id="score-selector" class="form-select">
                <option value="2">3/2</option>
                <option value="1">3/1</option>
                <option value="0">3/0</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="competition-selector" class="form-label fw-bold">{{ 'game.competition'|trans }}</label>
            <select id="competition-selector" class="form-select">
                <option value="SOLO">{{ 'game.solo'|trans }}</option>
                <option value="FRIENDS">{{ 'game.with_friends'|trans }}</option>
                <option value="TCO_CASUAL">{{ 'game.tco_casual'|trans }}</option>
                <option value="TCO_COMPETITIVE">{{ 'game.tco_competitive'|trans }}</option>
                <option value="LGS">{{ 'game.lgs'|trans }}</option>
                <option value="VT">{{ 'game.vt'|trans }}</option>
                <option value="NATIONAL">{{ 'game.national'|trans }}</option>
                <option value="NKFL">{{ 'game.nkfl'|trans }}</option>
                <option value="LOCAL_LEAGUE">{{ 'game.local_league'|trans }}</option>
                <option value="FRIENDS_LEAGUE">{{ 'game.friends_league'|trans }}</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="date-from-selector" class="form-label fw-bold">{{ 'menu.date_from'|trans }}</label>
            <input type="date" id="date-from-selector" class="form-control">
        </div>

        <div class="mb-3">
            <label for="date-to-selector" class="form-label fw-bold">{{ 'menu.date_to'|trans }}</label>
            <input type="date" id="date-to-selector" class="form-control">
        </div>

        <hr>
        <p class="text-muted small mb-2">{{ 'menu.log_stats_filters_note'|trans }}</p>

        {% set statGroups = [
            {
                label: 'menu.turns',
                stats: [
                    {key: 'turnsMin', label: 'menu.min'},
                    {key: 'turnsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_amber',
                stats: [
                    {key: 'winnerAmberObtainedMin', label: 'menu.min'},
                    {key: 'winnerAmberObtainedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_amber_stolen',
                stats: [
                    {key: 'winnerAmberStolenMin', label: 'menu.min'},
                    {key: 'winnerAmberStolenMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_cards_played',
                stats: [
                    {key: 'winnerCardsPlayedMin', label: 'menu.min'},
                    {key: 'winnerCardsPlayedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_cards_drawn',
                stats: [
                    {key: 'winnerCardsDrawnMin', label: 'menu.min'},
                    {key: 'winnerCardsDrawnMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_cards_discarded',
                stats: [
                    {key: 'winnerCardsDiscardedMin', label: 'menu.min'},
                    {key: 'winnerCardsDiscardedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_keys_forged',
                stats: [
                    {key: 'winnerKeysForgedMin', label: 'menu.min'},
                    {key: 'winnerKeysForgedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_fights',
                stats: [
                    {key: 'winnerFightsMin', label: 'menu.min'},
                    {key: 'winnerFightsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_reaps',
                stats: [
                    {key: 'winnerReapsMin', label: 'menu.min'},
                    {key: 'winnerReapsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.winner_extra_turns',
                stats: [
                    {key: 'winnerExtraTurnsMin', label: 'menu.min'},
                    {key: 'winnerExtraTurnsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_amber',
                stats: [
                    {key: 'loserAmberObtainedMin', label: 'menu.min'},
                    {key: 'loserAmberObtainedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_amber_stolen',
                stats: [
                    {key: 'loserAmberStolenMin', label: 'menu.min'},
                    {key: 'loserAmberStolenMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_cards_played',
                stats: [
                    {key: 'loserCardsPlayedMin', label: 'menu.min'},
                    {key: 'loserCardsPlayedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_cards_drawn',
                stats: [
                    {key: 'loserCardsDrawnMin', label: 'menu.min'},
                    {key: 'loserCardsDrawnMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_cards_discarded',
                stats: [
                    {key: 'loserCardsDiscardedMin', label: 'menu.min'},
                    {key: 'loserCardsDiscardedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_keys_forged',
                stats: [
                    {key: 'loserKeysForgedMin', label: 'menu.min'},
                    {key: 'loserKeysForgedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_fights',
                stats: [
                    {key: 'loserFightsMin', label: 'menu.min'},
                    {key: 'loserFightsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_reaps',
                stats: [
                    {key: 'loserReapsMin', label: 'menu.min'},
                    {key: 'loserReapsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.loser_extra_turns',
                stats: [
                    {key: 'loserExtraTurnsMin', label: 'menu.min'},
                    {key: 'loserExtraTurnsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_amber',
                stats: [
                    {key: 'totalAmberObtainedMin', label: 'menu.min'},
                    {key: 'totalAmberObtainedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_amber_stolen',
                stats: [
                    {key: 'totalAmberStolenMin', label: 'menu.min'},
                    {key: 'totalAmberStolenMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_cards_played',
                stats: [
                    {key: 'totalCardsPlayedMin', label: 'menu.min'},
                    {key: 'totalCardsPlayedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_cards_drawn',
                stats: [
                    {key: 'totalCardsDrawnMin', label: 'menu.min'},
                    {key: 'totalCardsDrawnMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_cards_discarded',
                stats: [
                    {key: 'totalCardsDiscardedMin', label: 'menu.min'},
                    {key: 'totalCardsDiscardedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_keys_forged',
                stats: [
                    {key: 'totalKeysForgedMin', label: 'menu.min'},
                    {key: 'totalKeysForgedMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_fights',
                stats: [
                    {key: 'totalFightsMin', label: 'menu.min'},
                    {key: 'totalFightsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_reaps',
                stats: [
                    {key: 'totalReapsMin', label: 'menu.min'},
                    {key: 'totalReapsMax', label: 'menu.max'},
                ]
            },
            {
                label: 'game.total_extra_turns',
                stats: [
                    {key: 'totalExtraTurnsMin', label: 'menu.min'},
                    {key: 'totalExtraTurnsMax', label: 'menu.max'},
                ]
            },
        ] %}

        {% for group in statGroups %}
            <div class="mb-2">
                <label class="form-label fw-bold mb-1">{{ group.label|trans }}</label>
                <div class="row g-1">
                    {% for stat in group.stats %}
                        <div class="col-6">
                            <input type="number" id="stat-{{ stat.key }}" class="form-control form-control-sm" placeholder="{{ stat.label|trans }}" min="0">
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
    <div class="offcanvas-footer">
        <div class="row mt-3 mb-3 ms-1 me-2">
            <div class="col-12 col-md-3 mb-3 mb-md-0">
                <button class="btn btn-dark w-100 text-nowrap" id="clearGamesFilters">
                    <i class="bi bi-arrow-repeat fs-8"></i>
                </button>
            </div>
            <div class="col-12 col-md-9">
                <button class="btn btn-dark w-100" id="applyGamesFilters">{{ 'menu.search'|trans }}</button>
            </div>
        </div>
    </div>
</div>

<script>
    const statKeys = [
        'turnsMin','turnsMax',
        'winnerAmberObtainedMin','winnerAmberObtainedMax',
        'winnerAmberStolenMin','winnerAmberStolenMax',
        'winnerCardsPlayedMin','winnerCardsPlayedMax',
        'winnerCardsDrawnMin','winnerCardsDrawnMax',
        'winnerCardsDiscardedMin','winnerCardsDiscardedMax',
        'winnerKeysForgedMin','winnerKeysForgedMax',
        'winnerFightsMin','winnerFightsMax',
        'winnerReapsMin','winnerReapsMax',
        'winnerExtraTurnsMin','winnerExtraTurnsMax',
        'loserAmberObtainedMin','loserAmberObtainedMax',
        'loserAmberStolenMin','loserAmberStolenMax',
        'loserCardsPlayedMin','loserCardsPlayedMax',
        'loserCardsDrawnMin','loserCardsDrawnMax',
        'loserCardsDiscardedMin','loserCardsDiscardedMax',
        'loserKeysForgedMin','loserKeysForgedMax',
        'loserFightsMin','loserFightsMax',
        'loserReapsMin','loserReapsMax',
        'loserExtraTurnsMin','loserExtraTurnsMax',
        'totalAmberObtainedMin','totalAmberObtainedMax',
        'totalAmberStolenMin','totalAmberStolenMax',
        'totalCardsPlayedMin','totalCardsPlayedMax',
        'totalCardsDrawnMin','totalCardsDrawnMax',
        'totalCardsDiscardedMin','totalCardsDiscardedMax',
        'totalKeysForgedMin','totalKeysForgedMax',
        'totalFightsMin','totalFightsMax',
        'totalReapsMin','totalReapsMax',
        'totalExtraTurnsMin','totalExtraTurnsMax',
    ];

    function updateGamesUrlFromFilters() {
        const params = new URLSearchParams();
        const addList = (key, values) => { if (values && values.length) params.set(key, values.join(',')); };

        addList('winner', $('#winner-selector').val());
        addList('loser', $('#loser-selector').val());
        addList('score', $('#score-selector').val());
        addList('competition', $('#competition-selector').val());

        if ($('#date-from-selector').val()) params.set('date_from', $('#date-from-selector').val());
        if ($('#date-to-selector').val()) params.set('date_to', $('#date-to-selector').val());

        statKeys.forEach(k => {
            const v = $('#stat-' + k).val();
            if (v !== '') params.set(k, v);
        });

        const base = window.location.pathname + (params.toString() ? ('?' + params.toString()) : '');
        window.history.replaceState({}, '', base);
    }

    function setGamesFiltersFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const csv = (v) => (v ? v.split(',').filter(Boolean) : []);
        const setSelect2 = (selector, values) => { if ($(selector).length) $(selector).val(values).trigger('change'); };

        setSelect2('#winner-selector', csv(params.get('winner')));
        setSelect2('#loser-selector', csv(params.get('loser')));
        setSelect2('#score-selector', csv(params.get('score')));
        setSelect2('#competition-selector', csv(params.get('competition')));

        if (params.has('date_from')) $('#date-from-selector').val(params.get('date_from'));
        if (params.has('date_to')) $('#date-to-selector').val(params.get('date_to'));

        statKeys.forEach(k => { if (params.has(k)) $('#stat-' + k).val(params.get(k)); });
    }

    document.addEventListener('DOMContentLoaded', function () {
        if (window.innerWidth >= 768) {
            document.getElementById('games-filters').classList.add('show');
        }

        setGamesFiltersFromUrl();

        $('#applyGamesFilters').on('click', function () {
            updateGamesUrlFromFilters();
            $('#gamesList').DataTable().ajax.reload();
        });

        $('#clearGamesFilters').on('click', function () {
            window.history.replaceState({}, '', window.location.pathname);
            location.reload();
        });
    });
</script>
