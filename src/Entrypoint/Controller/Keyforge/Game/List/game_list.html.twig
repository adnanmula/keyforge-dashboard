{% if show_inline_filters %}
<div class="form-group">
   <div class="row">
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.winner'|trans }}</label>
           <select id="winner-selector" class="form-select game_list_filter">
               {% for id,friend in friends %}
                   <option value="{{ id }}">{{ friend }}</option>
               {% endfor %}
           </select>
       </div>
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.loser'|trans }}</label>
           <select id="loser-selector" class="form-select game_list_filter">
               {% for id,friend in friends %}
                   <option value="{{ id }}">{{ friend }}</option>
               {% endfor %}
           </select>
       </div>
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.keys'|trans }}</label>
           <select id="score-selector" class="form-select game_list_filter">
               <option value="2">3/2</option>
               <option value="1">3/1</option>
               <option value="0">3/0</option>
           </select>
       </div>
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.competition'|trans }}</label>
           <select id="competition-selector" class="form-select game_list_filter">
               <option value="SOLO">{{ 'game.solo'|trans }}</option>
               <option value="FRIENDS" selected>{{ 'game.with_friends'|trans }}</option>
               <option value="TCO_CASUAL">{{ 'game.tco_casual'|trans }}</option>
               <option value="TCO_COMPETITIVE">{{ 'game.tco_competitive'|trans }}</option>
               <option value="LGS">{{ 'game.lgs'|trans }}</option>
               <option value="VT">{{ 'game.vt'|trans }}</option>
               <option value="NATIONAL">{{ 'game.national'|trans }}</option>
               <option value="NKFL">{{ 'game.nkfl'|trans }}</option>
               <option value="LOCAL_LEAGUE">{{ 'game.local_league'|trans }}</option>
           </select>
       </div>
   </div>
</div>
<div class="divider py-2"></div>
{% endif %}
<div class="" style="display: flex; overflow-x: auto">
    <table id="gamesList" class="table table-responsive-sm table-hover" style="width:100%;">
        <thead>
        <tr>
            <th scope="col">{{ 'game.winner'|trans }}</th>
            <th scope="col">{{ 'game.winner_deck'|trans }}</th>
            <th scope="col">{{ 'game.loser'|trans }}</th>
            <th scope="col">{{ 'game.loser_deck'|trans }}</th>
            <th scope="col">{{ 'game.keys'|trans }}</th>
            <th scope="col">{{ 'game.first_turn'|trans }}</th>
            <th scope="col">{{ 'game.date'|trans }}</th>
            <th scope="col">{{ 'game.competition'|trans }}</th>
            <th scope="col"></th>
        </tr>
        </thead>
    </table>
</div>

<script>
    function prepareSelectors(id) {
        $('#' + id).select2({
            multiple: true,
            closeOnSelect: true,
            allowClear: false,
            placeholder: '',
            theme: 'bootstrap-5',
        });

        $('#' + id).val("")
        $('#' + id).trigger("change");
    }

    function winnerFilter() {
        return $('#winner-selector').val();
    }

    function loserFilter() {
        return $('#loser-selector').val();
    }

    function scoreFilter() {
        return $('#score-selector').val();
    }

    function competitionFilter() {
        return $('#competition-selector').val();
    }

    function dateFromFilter() {
        return $('#date-from-selector').val();
    }

    function dateToFilter() {
        return $('#date-to-selector').val();
    }

    function statVal(id) {
        const v = $('#' + id).val();
        return v !== '' ? v : null;
    }

    $(document).ready(function () {
        prepareSelectors('winner-selector');
        prepareSelectors('loser-selector');
        prepareSelectors('score-selector');
        prepareSelectors('competition-selector');

        if (typeof setGamesFiltersFromUrl === 'function') {
            setGamesFiltersFromUrl();
        }

        $('.game_list_filter').change(function (e) {
            $('#gamesList').DataTable().ajax.reload();
        });

        $(window).on('resize', function() {
            $('#gamesList.dataTable').resize;
        });

        $('#gamesList').DataTable({
            searching: false,
            paging: true,
            info: true,
            responsive: true,
            processing: true,
            serverSide: true,
            order: [[6, 'desc']],
            lengthMenu: [10, 25, 50, 100],
            iDisplayLength: 25,
            ajax: {
                {% if deck_reference is null %}
                    url: '{{ path('keyforge_games_json', {'userId': user_reference}) }}',
                {% else %}
                    url: '{{ path('keyforge_games_json', {'deckId': deck_reference}) }}',
                {% endif %}
                data: function(d){
                    d.extraFilterWinner = winnerFilter();
                    d.extraFilterLoser = loserFilter();
                    d.extraFilterScore = scoreFilter();
                    d.extraFilterCompetition = competitionFilter();
                    d.extraFilterDateFrom = dateFromFilter();
                    d.extraFilterDateTo = dateToFilter();
                    const statIds = [
                        'turnsMin','turnsMax',
                        'winnerAmberObtainedMin','winnerAmberObtainedMax',
                        'winnerAmberStolenMin','winnerAmberStolenMax',
                        'winnerCardsPlayedMin','winnerCardsPlayedMax',
                        'winnerCardsDrawnMin','winnerCardsDrawnMax',
                        'winnerCardsDiscardedMin','winnerCardsDiscardedMax',
                        'winnerKeysForgedMin','winnerKeysForgedMax',
                        'winnerFightsMin','winnerFightsMax',
                        'winnerReapsMin','winnerReapsMax',
                        'winnerExtraTurnsMin','winnerExtraTurnsMax',
                        'loserAmberObtainedMin','loserAmberObtainedMax',
                        'loserAmberStolenMin','loserAmberStolenMax',
                        'loserCardsPlayedMin','loserCardsPlayedMax',
                        'loserCardsDrawnMin','loserCardsDrawnMax',
                        'loserCardsDiscardedMin','loserCardsDiscardedMax',
                        'loserKeysForgedMin','loserKeysForgedMax',
                        'loserFightsMin','loserFightsMax',
                        'loserReapsMin','loserReapsMax',
                        'loserExtraTurnsMin','loserExtraTurnsMax',
                        'totalAmberObtainedMin','totalAmberObtainedMax',
                        'totalAmberStolenMin','totalAmberStolenMax',
                        'totalCardsPlayedMin','totalCardsPlayedMax',
                        'totalCardsDrawnMin','totalCardsDrawnMax',
                        'totalCardsDiscardedMin','totalCardsDiscardedMax',
                        'totalKeysForgedMin','totalKeysForgedMax',
                        'totalFightsMin','totalFightsMax',
                        'totalReapsMin','totalReapsMax',
                        'totalExtraTurnsMin','totalExtraTurnsMax',
                    ];
                    statIds.forEach(k => { const v = statVal('stat-' + k); if (v !== null) d[k] = v; });
                }
            },
            createdRow: function(row, data) {
                let deck = '{{ deck_reference }}';
                let user = '{{ user_reference }}';

                const isWin = deck === data.{{ reference_type }} || user === data.{{ reference_type }};
                $(row).css('background-color', isWin
                    ? 'rgba(25, 135, 84, 0.25)'
                    : 'rgba(220, 53, 69, 0.25)'
                );
            },
            drawCallback: function () {
                $('[data-toggle="tooltip"]').tooltip({
                    container: 'body',
                    placement: 'top',
                });
            },
            columns: [
                { data: "winner_name" },
                { data: "winner_deck_name" },
                { data: "loser_name" },
                { data: "loser_deck_name" },
                { data: "score" },
                { data: "first_turn" },
                { data: "date" },
                { data: "competition" },
                { data: "notes" },
            ],
            columnDefs: [
                {
                    render: function (data, type, row) {
                        if (null === row.winner) {
                            return data;
                        }

                        return '<a href="/user/' + row.winner + '">' + data + '</a>';
                    },
                    targets: 0, //Winner
                },
                {
                    render: function (data, type, row) {
                        let reference = '{{ deck_reference }}';

                        let firstIcon = '';
                        if (row.first_turn === row.winner_name) {
                            firstIcon = ' <i class="bi bi-lightning-fill text-primary" data-toggle="tooltip" title="Primer turno"></i>';
                        }

                        if (reference === row.winner_deck) {
                            return data + firstIcon;
                        } else {
                            return '<a href="/deck/' + row.winner_deck + '">' + data + '</a>' + firstIcon;
                        }
                    },
                    targets: 1, //Winner deck
                },
                {
                    render: function (data, type, row) {
                        if (null === row.loser) {
                            return data;
                        }

                        return '<a href="/user/' + row.loser + '">' + data + '</a>';
                    },
                    targets: 2, //Loser
                },
                {
                    render: function (data, type, row) {
                        let reference = '{{ deck_reference }}';

                        let firstIcon = '';
                        if (row.first_turn === row.loser_name) {
                            firstIcon = ' <i class="bi bi-lightning-fill text-primary" data-toggle="tooltip" title="Primer turno"></i>';
                        }

                        if (reference === row.loser_deck) {
                            return data + firstIcon;
                        } else {
                            return '<a href="/deck/' + row.loser_deck + '">' + data + '</a>' + firstIcon;
                        }
                    },
                    targets: 3, //Loser deck
                },
                {
                    render: function (data, type, row) {
                        return '<span class="badge bg-secondary fs-6">' + data + '</span>';
                    },
                    targets: 4, //Score
                },
                {
                    render: function (data, type, row) {
                        const competitionColors = {
                            'Solo':             'bg-secondary',
                            'Friendly':         'bg-success',
                            'Friendly League':  'bg-success',
                            'TCO Casual':       'bg-info text-dark',
                            'TCO Competitive':  'bg-primary',
                            'Local League':     'bg-warning text-dark',
                            'LGS':              'bg-dark',
                            'VT':               'bg-dark',
                            'NATIONAL':         'bg-dark',
                            'NKFL':             'bg-dark',
                        };

                        const colorClass = competitionColors[data] || 'bg-secondary';
                        return '<span class="badge ' + colorClass + '">' + data + '</span>';
                    },
                    targets: 7, //Competition
                },
                {
                    render: function (data, type, row) {
                        let items = [];

                        if (row.loser_deck === row.winner_deck) {
                            items.push('<span class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="{{ 'game.mirror'|trans }}">M</span>');
                        }

                        if (null !== row.winner && null !== row.loser && row.loser === row.winner) {
                            items.push('<span class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="{{ 'game.solo'|trans }}">S</span>');
                        }

                        if ('' !== row.notes) {
                            items.push('<span class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="' + row.notes + '"><i class="bi bi-journal-text"></i></span>');
                        }

                        if (null !== row.logId) {
                            let url = '{{ path('keyforge_game_log', {'id': '-replace-'}) }}';
                            url = url.replace('-replace-', row.logId);

                            items.push('<a href="' + url + '" target="_blank" class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="{{ 'menu.game_log_tooltip'|trans }}">'
                                + '<i class="bi bi-bar-chart-line-fill me-1"></i></a>');
                        }

                        return '<div style="display: inline-flex; gap: 0.25rem; align-items: center; white-space: nowrap">' + items.join('') + '</div>';
                    },
                    targets: 8, //Notes
                },
                {
                    targets: [0, 1, 2, 3, 4, 6, 7, 8],
                    searchable: false,
                    visible: true,
                },
                {
                    targets: [5],
                    visible: false,
                },
                {
                    targets: [0, 1, 2, 3, 4, 5, 7, 8],
                    orderable: false,
                },
                {
                    targets: [6],
                    orderable: true,
                },
                { width: 150, targets: 0 },
                { width: 300, targets: 1 },
                { width: 150, targets: 2 },
                { width: 300, targets: 3 },
                { width: 100, targets: 6 },
                { width: 250, targets: 7 },
                { targets: [8], className: 'text-nowrap' },
            ],
        });
    });
</script>
