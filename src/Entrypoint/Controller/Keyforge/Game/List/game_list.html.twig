{% if show_inline_filters %}
<div class="form-group">
   <div class="row">
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.winner'|trans }}</label>
           <select id="winner-selector" class="form-select game_list_filter">
               {% for id,friend in friends %}
                   <option value="{{ id }}">{{ friend }}</option>
               {% endfor %}
           </select>
       </div>
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.loser'|trans }}</label>
           <select id="loser-selector" class="form-select game_list_filter">
               {% for id,friend in friends %}
                   <option value="{{ id }}">{{ friend }}</option>
               {% endfor %}
           </select>
       </div>
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.keys'|trans }}</label>
           <select id="score-selector" class="form-select game_list_filter">
               <option value="2">3/2</option>
               <option value="1">3/1</option>
               <option value="0">3/0</option>
           </select>
       </div>
       <div class="col-12 col-sm-6 col-md-3">
           <label>{{ 'game.competition'|trans }}</label>
           <select id="competition-selector" class="form-select game_list_filter">
               <option value="SOLO">{{ 'game.solo'|trans }}</option>
               <option value="FRIENDS" selected>{{ 'game.with_friends'|trans }}</option>
               <option value="TCO_CASUAL">{{ 'game.tco_casual'|trans }}</option>
               <option value="TCO_COMPETITIVE">{{ 'game.tco_competitive'|trans }}</option>
               <option value="LGS">{{ 'game.lgs'|trans }}</option>
               <option value="VT">{{ 'game.vt'|trans }}</option>
               <option value="NATIONAL">{{ 'game.national'|trans }}</option>
               <option value="NKFL">{{ 'game.nkfl'|trans }}</option>
               <option value="LOCAL_LEAGUE">{{ 'game.local_league'|trans }}</option>
           </select>
       </div>
   </div>
</div>
<div class="divider py-2"></div>
{% endif %}
<style>
    .games-scroll-mirror {
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: thin;
        scrollbar-color: #6c757d transparent;
        margin-bottom: 4px;
    }
    .games-scroll-mirror::-webkit-scrollbar { height: 6px; }
    .games-scroll-mirror::-webkit-scrollbar-track { background: transparent; }
    .games-scroll-mirror::-webkit-scrollbar-thumb { background-color: #6c757d; border-radius: 3px; }
    .games-scroll-mirror-inner { height: 1px; }

    .games-table-wrap {
        position: relative;
        overflow-x: auto;
        border-radius: 0.375rem;
        scrollbar-width: thin;
        scrollbar-color: #6c757d transparent;
        cursor: grab;
        user-select: none;
    }
    .games-table-wrap.is-dragging { cursor: grabbing; }
    .games-table-wrap::-webkit-scrollbar { height: 6px; }
    .games-table-wrap::-webkit-scrollbar-track { background: transparent; }
    .games-table-wrap::-webkit-scrollbar-thumb { background-color: #6c757d; border-radius: 3px; }

    /* scroll-shadow: fade left/right edges when content is cut off */
    .games-table-wrap::before,
    .games-table-wrap::after {
        content: '';
        position: absolute;
        top: 0; bottom: 0;
        width: 32px;
        pointer-events: none;
        z-index: 10;
        transition: opacity .15s;
    }
    .games-table-wrap::before { left: 0;  background: linear-gradient(to right, rgba(var(--bs-body-bg-rgb, 255,255,255), .95), transparent); }
    .games-table-wrap::after  { right: 0; background: linear-gradient(to left,  rgba(var(--bs-body-bg-rgb, 255,255,255), .95), transparent); }
    .games-table-wrap.scroll-start::before { opacity: 0; }
    .games-table-wrap.scroll-end::after   { opacity: 0; }

    /* sticky columns */
    #gamesList thead th:nth-child(1),
    #gamesList tbody td:nth-child(1) { position: sticky; left: 0;   z-index: 2; background: inherit; }
    #gamesList thead th:nth-child(2),
    #gamesList tbody td:nth-child(2) { position: sticky; left: 120px; z-index: 2; background: inherit; }
    #gamesList thead th:nth-child(3),
    #gamesList tbody td:nth-child(3) { position: sticky; left: 320px; z-index: 2; background: inherit; }
    #gamesList thead th:nth-child(4),
    #gamesList tbody td:nth-child(4) { position: sticky; left: 440px; z-index: 2; background: inherit; }
    #gamesList thead th:last-child,
    #gamesList tbody td:last-child   { position: sticky; right: 0;  z-index: 2; background: inherit; }

    #gamesList thead th { background: var(--bs-table-bg, #fff); }
</style>
<div class="games-scroll-mirror" id="gamesScrollMirror">
    <div class="games-scroll-mirror-inner" id="gamesScrollInner"></div>
</div>
<div class="games-table-wrap" id="gamesTableWrap">
    <table id="gamesList" class="table table-responsive-sm table-hover" style="width:100%;">
        <thead>
        <tr>
            <th scope="col">{{ 'game.winner'|trans }}</th>
            <th scope="col">{{ 'game.winner_deck'|trans }}</th>
            <th scope="col">{{ 'game.loser'|trans }}</th>
            <th scope="col">{{ 'game.loser_deck'|trans }}</th>
            <th scope="col">{{ 'game.keys'|trans }}</th>
            <th scope="col">{{ 'game.first_turn'|trans }}</th>
            <th scope="col">{{ 'game.date'|trans }}</th>
            <th scope="col">{{ 'game.competition'|trans }}</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'menu.turns'|trans }}">T</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_amber'|trans }}">W.Amb</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_amber_stolen'|trans }}">W.Stl</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_cards_played'|trans }}">W.Cp</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_cards_drawn'|trans }}">W.Cd</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_cards_discarded'|trans }}">W.Cx</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_keys_forged'|trans }}">W.K</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_fights'|trans }}">W.F</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_reaps'|trans }}">W.R</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.winner_extra_turns'|trans }}">W.+T</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_amber'|trans }}">L.Amb</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_amber_stolen'|trans }}">L.Stl</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_cards_played'|trans }}">L.Cp</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_cards_drawn'|trans }}">L.Cd</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_cards_discarded'|trans }}">L.Cx</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_keys_forged'|trans }}">L.K</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_fights'|trans }}">L.F</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_reaps'|trans }}">L.R</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.loser_extra_turns'|trans }}">L.+T</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_amber'|trans }}">∑.Amb</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_amber_stolen'|trans }}">∑.Stl</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_cards_played'|trans }}">∑.Cp</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_cards_drawn'|trans }}">∑.Cd</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_cards_discarded'|trans }}">∑.Cx</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_keys_forged'|trans }}">∑.K</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_fights'|trans }}">∑.F</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_reaps'|trans }}">∑.R</th>
            <th scope="col" data-toggle="tooltip" title="{{ 'game.total_extra_turns'|trans }}">∑.+T</th>
            <th scope="col"></th>
        </tr>
        </thead>
    </table>
</div>

<script>
    function prepareSelectors(id) {
        $('#' + id).select2({
            multiple: true,
            closeOnSelect: true,
            allowClear: false,
            placeholder: '',
            theme: 'bootstrap-5',
        });

        $('#' + id).val("")
        $('#' + id).trigger("change");
    }

    function winnerFilter() {
        return $('#winner-selector').val();
    }

    function loserFilter() {
        return $('#loser-selector').val();
    }

    function scoreFilter() {
        return $('#score-selector').val();
    }

    function competitionFilter() {
        return $('#competition-selector').val();
    }

    function dateFromFilter() {
        return $('#date-from-selector').val();
    }

    function dateToFilter() {
        return $('#date-to-selector').val();
    }

    function statVal(id) {
        const v = $('#' + id).val();
        return v !== '' ? v : null;
    }

    function renderStatVal(data, key) {
        if (!data) { return '<span class="text-muted">—</span>'; }
        const v = data[key];
        return (v !== null && v !== undefined) ? v : '<span class="text-muted">—</span>';
    }

    function updateScrollShadows() {
        const wrap = document.getElementById('gamesTableWrap');
        if (!wrap) return;
        const atStart = wrap.scrollLeft <= 2;
        const atEnd   = wrap.scrollLeft + wrap.clientWidth >= wrap.scrollWidth - 2;
        wrap.classList.toggle('scroll-start', atStart);
        wrap.classList.toggle('scroll-end',   atEnd);
    }

    function initTableScroll() {
        const wrap   = document.getElementById('gamesTableWrap');
        const mirror = document.getElementById('gamesScrollMirror');
        const inner  = document.getElementById('gamesScrollInner');
        if (!wrap || !mirror || !inner) return;

        // keep mirror width in sync with table
        function syncInnerWidth() {
            inner.style.width = document.getElementById('gamesList').scrollWidth + 'px';
        }
        syncInnerWidth();
        new ResizeObserver(syncInnerWidth).observe(document.getElementById('gamesList'));

        // bidirectional scroll sync (guard re-entrancy)
        let syncing = false;
        mirror.addEventListener('scroll', () => { if (!syncing) { syncing = true; wrap.scrollLeft = mirror.scrollLeft; syncing = false; } }, { passive: true });
        wrap.addEventListener('scroll', () => {
            if (!syncing) { syncing = true; mirror.scrollLeft = wrap.scrollLeft; syncing = false; }
            updateScrollShadows();
        }, { passive: true });

        // drag to scroll
        let dragging = false, startX = 0, startScroll = 0, moved = false;
        wrap.addEventListener('mousedown', (e) => {
            if (e.button !== 0 || e.target.closest('a, button, input, select, th')) return;
            dragging = true; moved = false;
            startX = e.pageX;
            startScroll = wrap.scrollLeft;
            wrap.classList.add('is-dragging');
        });
        document.addEventListener('mousemove', (e) => {
            if (!dragging) return;
            const dx = startX - e.pageX;
            if (Math.abs(dx) > 3) { moved = true; wrap.scrollLeft = startScroll + dx; }
        });
        document.addEventListener('mouseup', () => {
            if (!dragging) return;
            dragging = false;
            wrap.classList.remove('is-dragging');
            // suppress click if it was a drag
            if (moved) { wrap.addEventListener('click', (e) => e.stopPropagation(), { once: true, capture: true }); }
        });

        updateScrollShadows();
    }

    $(document).ready(function () {
        prepareSelectors('winner-selector');
        prepareSelectors('loser-selector');
        prepareSelectors('score-selector');
        prepareSelectors('competition-selector');

        if (typeof setGamesFiltersFromUrl === 'function') {
            setGamesFiltersFromUrl();
        }

        initTableScroll();

        $('.game_list_filter').change(function (e) {
            $('#gamesList').DataTable().ajax.reload();
        });

        $(window).on('resize', function() {
            $('#gamesList.dataTable').resize;
        });

        const statColumns = [
            { key: 'turns' },
            { key: 'winner_amber_obtained' }, { key: 'winner_amber_stolen' },
            { key: 'winner_cards_played' }, { key: 'winner_cards_drawn' }, { key: 'winner_cards_discarded' },
            { key: 'winner_keys_forged' }, { key: 'winner_fights' }, { key: 'winner_reaps' }, { key: 'winner_extra_turns' },
            { key: 'loser_amber_obtained' }, { key: 'loser_amber_stolen' },
            { key: 'loser_cards_played' }, { key: 'loser_cards_drawn' }, { key: 'loser_cards_discarded' },
            { key: 'loser_keys_forged' }, { key: 'loser_fights' }, { key: 'loser_reaps' }, { key: 'loser_extra_turns' },
            { key: 'total_amber_obtained' }, { key: 'total_amber_stolen' },
            { key: 'total_cards_played' }, { key: 'total_cards_drawn' }, { key: 'total_cards_discarded' },
            { key: 'total_keys_forged' }, { key: 'total_fights' }, { key: 'total_reaps' }, { key: 'total_extra_turns' },
        ];
        const statStartIdx = 8;
        const actionsIdx = statStartIdx + statColumns.length; // 36

        const statColumnDefs = statColumns.map(({ key }, i) => ({
            targets: statStartIdx + i,
            data: 'logStats',
            orderable: true,
            searchable: false,
            render: (d) => renderStatVal(d, key),
            width: 45,
        }));

        $('#gamesList').DataTable({
            searching: false,
            paging: true,
            info: true,
            responsive: false,
            processing: true,
            serverSide: true,
            order: [[6, 'desc']],
            lengthMenu: [10, 25, 50, 100],
            iDisplayLength: 25,
            ajax: {
                {% if deck_reference is null %}
                    url: '{{ path('keyforge_games_json', {'userId': user_reference}) }}',
                {% else %}
                    url: '{{ path('keyforge_games_json', {'deckId': deck_reference}) }}',
                {% endif %}
                type: 'POST',
                data: function(d){
                    d.extraFilterWinner = winnerFilter();
                    d.extraFilterLoser = loserFilter();
                    d.extraFilterScore = scoreFilter();
                    d.extraFilterCompetition = competitionFilter();
                    d.extraFilterDateFrom = dateFromFilter();
                    d.extraFilterDateTo = dateToFilter();
                    const statIds = [
                        'turnsMin','turnsMax',
                        'winnerAmberObtainedMin','winnerAmberObtainedMax',
                        'winnerAmberStolenMin','winnerAmberStolenMax',
                        'winnerCardsPlayedMin','winnerCardsPlayedMax',
                        'winnerCardsDrawnMin','winnerCardsDrawnMax',
                        'winnerCardsDiscardedMin','winnerCardsDiscardedMax',
                        'winnerKeysForgedMin','winnerKeysForgedMax',
                        'winnerFightsMin','winnerFightsMax',
                        'winnerReapsMin','winnerReapsMax',
                        'winnerExtraTurnsMin','winnerExtraTurnsMax',
                        'loserAmberObtainedMin','loserAmberObtainedMax',
                        'loserAmberStolenMin','loserAmberStolenMax',
                        'loserCardsPlayedMin','loserCardsPlayedMax',
                        'loserCardsDrawnMin','loserCardsDrawnMax',
                        'loserCardsDiscardedMin','loserCardsDiscardedMax',
                        'loserKeysForgedMin','loserKeysForgedMax',
                        'loserFightsMin','loserFightsMax',
                        'loserReapsMin','loserReapsMax',
                        'loserExtraTurnsMin','loserExtraTurnsMax',
                        'totalAmberObtainedMin','totalAmberObtainedMax',
                        'totalAmberStolenMin','totalAmberStolenMax',
                        'totalCardsPlayedMin','totalCardsPlayedMax',
                        'totalCardsDrawnMin','totalCardsDrawnMax',
                        'totalCardsDiscardedMin','totalCardsDiscardedMax',
                        'totalKeysForgedMin','totalKeysForgedMax',
                        'totalFightsMin','totalFightsMax',
                        'totalReapsMin','totalReapsMax',
                        'totalExtraTurnsMin','totalExtraTurnsMax',
                    ];
                    statIds.forEach(k => { const v = statVal('stat-' + k); if (v !== null) d[k] = v; });
                }
            },
            createdRow: function(row, data) {
                let deck = '{{ deck_reference }}';
                let user = '{{ user_reference }}';

                const isWin = deck === data.{{ reference_type }} || user === data.{{ reference_type }};
                $(row).css('background-color', isWin
                    ? 'rgba(25, 135, 84, 0.25)'
                    : 'rgba(220, 53, 69, 0.25)'
                );
            },
            drawCallback: function () {
                $('[data-toggle="tooltip"]').tooltip({ container: 'body', placement: 'top' });
                updateScrollShadows();
                document.getElementById('gamesScrollInner').style.width =
                    document.getElementById('gamesList').scrollWidth + 'px';
            },
            columns: [
                { data: 'winner_name' },
                { data: 'winner_deck_name' },
                { data: 'loser_name' },
                { data: 'loser_deck_name' },
                { data: 'score' },
                { data: 'first_turn' },
                { data: 'date' },
                { data: 'competition' },
                ...statColumns.map(() => ({ data: 'logStats' })),
                { data: 'notes' },
            ],
            columnDefs: [
                {
                    render: function (data, type, row) {
                        if (null === row.winner) { return data; }
                        return '<a href="/user/' + row.winner + '">' + data + '</a>';
                    },
                    targets: 0,
                },
                {
                    render: function (data, type, row) {
                        let reference = '{{ deck_reference }}';
                        let firstIcon = '';
                        if (row.first_turn === row.winner_name) {
                            firstIcon = ' <i class="bi bi-lightning-fill text-primary" data-toggle="tooltip" title="Primer turno"></i>';
                        }
                        return reference === row.winner_deck
                            ? data + firstIcon
                            : '<a href="/deck/' + row.winner_deck + '">' + data + '</a>' + firstIcon;
                    },
                    targets: 1,
                },
                {
                    render: function (data, type, row) {
                        if (null === row.loser) { return data; }
                        return '<a href="/user/' + row.loser + '">' + data + '</a>';
                    },
                    targets: 2,
                },
                {
                    render: function (data, type, row) {
                        let reference = '{{ deck_reference }}';
                        let firstIcon = '';
                        if (row.first_turn === row.loser_name) {
                            firstIcon = ' <i class="bi bi-lightning-fill text-primary" data-toggle="tooltip" title="Primer turno"></i>';
                        }
                        return reference === row.loser_deck
                            ? data + firstIcon
                            : '<a href="/deck/' + row.loser_deck + '">' + data + '</a>' + firstIcon;
                    },
                    targets: 3,
                },
                {
                    render: function (data) {
                        return '<span class="badge bg-secondary fs-6">' + data + '</span>';
                    },
                    targets: 4,
                },
                {
                    render: function (data) {
                        const competitionColors = {
                            'Solo':             'bg-secondary',
                            'Friendly':         'bg-success',
                            'Friendly League':  'bg-success',
                            'TCO Casual':       'bg-info text-dark',
                            'TCO Competitive':  'bg-primary',
                            'Local League':     'bg-warning text-dark',
                            'LGS':              'bg-dark',
                            'VT':               'bg-dark',
                            'NATIONAL':         'bg-dark',
                            'NKFL':             'bg-dark',
                        };
                        const colorClass = competitionColors[data] || 'bg-secondary';
                        return '<span class="badge ' + colorClass + '">' + data + '</span>';
                    },
                    targets: 7,
                },
                ...statColumnDefs,
                {
                    render: function (data, type, row) {
                        let items = [];
                        if (row.loser_deck === row.winner_deck) {
                            items.push('<span class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="{{ 'game.mirror'|trans }}">M</span>');
                        }
                        if (null !== row.winner && null !== row.loser && row.loser === row.winner) {
                            items.push('<span class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="{{ 'game.solo'|trans }}">S</span>');
                        }
                        if ('' !== row.notes) {
                            items.push('<span class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="' + row.notes + '"><i class="bi bi-journal-text"></i></span>');
                        }
                        if (null !== row.logId) {
                            let url = '{{ path('keyforge_game_log', {'id': '-replace-'}) }}';
                            url = url.replace('-replace-', row.logId);
                            items.push('<a href="' + url + '" target="_blank" class="btn btn-sm btn-outline-dark" data-toggle="tooltip" title="{{ 'menu.game_log_tooltip'|trans }}">'
                                + '<i class="bi bi-bar-chart-line-fill me-1"></i></a>');
                        }
                        return '<div style="display:inline-flex;gap:0.25rem;align-items:center;white-space:nowrap">' + items.join('') + '</div>';
                    },
                    orderable: false,
                    searchable: false,
                    targets: actionsIdx,
                    className: 'text-nowrap',
                },
                { targets: [0, 1, 2, 3, 4, 6, 7], searchable: false, orderable: false },
                { targets: [6], orderable: true },
                { targets: [5], visible: false },
                { width: 120, targets: 0 },
                { width: 200, targets: 1 },
                { width: 120, targets: 2 },
                { width: 200, targets: 3 },
                { width: 60,  targets: 4 },
                { width: 90,  targets: 6 },
                { width: 150, targets: 7 },
            ],
        });
    });
</script>
