{
    "name": "adnanmula/card-game-stats",
    "description": "",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "adnanmula/criteria": "^0.5.0",
        "adnanmula/keyforge-game-log-parser": "dev-master",
        "adnanmula/tournament": "dev-master",
        "beberlei/assert": "^3.3",
        "doctrine/dbal": "^4.3",
        "nelmio/api-doc-bundle": "^5.0",
        "ramsey/uuid": "^4.7",
        "robmorgan/phinx": "^0.16",
        "symfony/asset": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/lock": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/monolog-bundle": "^4",
        "symfony/rate-limiter": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/yaml": "8.1.*"
    },
    "require-dev": {
        "adnanmula/coding-standard": "^0.0.13",
        "phpro/grumphp": "^2.9",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "bin-dir": "bin",
        "platform-check": false,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpro/grumphp": false,
            "symfony/flex": true
        },
        "platform": {
            "php": "8.4.20"
        }
    },
    "autoload": {
        "psr-4": {
            "AdnanMula\\Cards\\": "src/",
            "AdnanMula\\Cards\\Migrations\\": "migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdnanMula\\Cards\\Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "post-autoload-dump": [
            "rm -rf .git/hooks",
            "cp -r scripts/git-hooks .git/hooks"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    }
}
